# Database (PostgreSQL)
#  - local : Supabase CLI 起動後に `supabase status` で取得
#  - 本番(Vercel) : Supabase の Transaction pooler 接続文字列 (port 6543, 末尾に ?pgbouncer=true)
#    例) postgresql://postgres.<ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
#    ※ drizzle-kit migrate は Direct/Session 接続 (port 5432) を使うこと
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase (local) — MVP では未使用 (将来の認証用)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# OpenAI (必須)
OPENAI_API_KEY=
