{
  "name": "workflow-interviewer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs migrate",
    "check:kb": "tsx scripts/check-kb-parser.ts",
    "check:slots": "tsx scripts/check-slots.ts",
    "check:node-coverage": "tsx scripts/check-node-coverage.ts",
    "check:progress": "tsx scripts/check-progress.ts",
    "check:kb-seed": "tsx scripts/check-kb-seed.ts",
    "check:risks": "tsx scripts/check-risks.ts",
    "check:cautions": "tsx scripts/check-cautions.ts",
    "check:gap-match": "node --env-file-if-exists=.env.local --import tsx scripts/check-gap-match.ts",
    "check:gap-diff": "node --env-file-if-exists=.env.local --import tsx scripts/check-gap-diff.ts",
    "check:gap-recompute": "node --env-file-if-exists=.env.local --import tsx scripts/check-gap-recompute.ts",
    "check:workflows": "tsx scripts/check-workflows.ts",
    "check:flow-graph": "tsx scripts/check-flow-graph.ts",
    "check:export": "tsx scripts/check-export.ts",
    "check:mermaid-preprocess": "tsx scripts/check-mermaid-preprocess.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hono/zod-validator": "^0.7.6",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.12",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.15.0",
    "nanoid": "^5.1.7",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
